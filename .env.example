# SpecKit Agent System - Environment Configuration
#
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Anthropic API Configuration
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: Anthropic API Configuration
# ANTHROPIC_API_URL=https://api.anthropic.com  # Custom API endpoint (if needed)
# ANTHROPIC_API_VERSION=2023-06-01  # API version (default is latest)

# Optional: Model Configuration
# DEFAULT_MODEL=claude-sonnet-4-5  # Default Claude model to use
# MAX_TOKENS=4096  # Maximum tokens for API responses

# Optional: Logging Configuration
# LOG_LEVEL=INFO  # Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_FILE=agent.log  # Log file path (leave empty for console only)

# Optional: Git Configuration
# GIT_USER_NAME=SpecKit Agent  # Git commit author name
# GIT_USER_EMAIL=agent@speckit.dev  # Git commit author email

# Optional: Workflow Configuration
# WORKFLOW_STATE_FILE=.specify/state.yaml  # Path to workflow state file
# CONSTITUTION_FILE=.specify/memory/constitution.md  # Path to constitution file

# Optional: SMTP Configuration (required for send_email event)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=you@gmail.com
